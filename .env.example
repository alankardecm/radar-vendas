# Copie para .env e preencha. PoC funciona com chaves GRATUITAS.

# Visao da fachada. Pegue uma chave gratis em https://aistudio.google.com/apikey
GEMINI_API_KEY=cole_sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# (Opcional) Google Places para confirmar empresa/endereco com mais precisao.
# Tem credito gratis de US$200/mes. Deixe vazio para pular.
GOOGLE_PLACES_API_KEY=cole_sua_chave_places_aqui

PORT=4500
